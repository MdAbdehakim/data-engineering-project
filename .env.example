# ── Hadoop ────────────────────────────────────────────────────────────────────
HADOOP_HOME=./hadoop

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC=transactions_ecommerce

# ── Delta Lake paths ─────────────────────────────────────────────────────────
DELTA_OUTPUT_PATH=./delta/output
DELTA_CHECKPOINT_PATH=./delta/checkpoints

# ── Spark packages (override only if changing Spark/Delta versions) ──────────
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.1
DELTA_SPARK_PACKAGE=io.delta:delta-spark_2.12:3.1.0
